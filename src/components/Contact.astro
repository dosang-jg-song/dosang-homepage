---
const CONTACT_INFO = [
  ["Office", "부산광역시 남구 용호로42번길 104-11", "사무동 1층, South Korea"],
  ["Email", "jg.song@dosang.kr", ""],
  ["Hours", "Mon — Fri", "09:00 – 18:00 KST"],
];
---
<section id="contact" class="section section--subtle">
  <div class="container">
    <div class="grid-12 contact-grid">
      <div class="contact-info-col reveal">
        <p class="eyebrow">07 · Contact</p>
        <h2 class="h-1">Briefing 요청</h2>
        <p class="lead measure contact-lead">
          글로벌 SAP·Tax·AX 도입을 검토 중이시면 우선 30분 Briefing을 요청하십시오.
          기술 컨설턴트가 직접 응답합니다.
        </p>
        <dl class="contact-info-list">
          {CONTACT_INFO.map(([label, line1, line2]) => (
            <div class="contact-info-row">
              <dt>{label}</dt>
              <dd>
                <div>{line1}</div>
                {line2 && <div class="contact-info-sub">{line2}</div>}
              </dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="contact-form-col reveal">
        <form id="contact-form" novalidate>
          <div class="form-row">
            <label for="cf-name">이름 *</label>
            <input id="cf-name" name="name" type="text" autocomplete="name" required />
            <span class="form-err" data-err="name"></span>
          </div>
          <div class="form-row">
            <label for="cf-company">회사명 *</label>
            <input id="cf-company" name="company" type="text" autocomplete="organization" required />
            <span class="form-err" data-err="company"></span>
          </div>
          <div class="form-row">
            <label for="cf-email">이메일 *</label>
            <input id="cf-email" name="email" type="email" autocomplete="email" required />
            <span class="form-err" data-err="email"></span>
          </div>
          <div class="form-row">
            <label for="cf-message">문의 내용 *</label>
            <textarea id="cf-message" name="message" rows="5" required></textarea>
            <span class="form-err" data-err="message"></span>
          </div>
          <p class="form-note">전송 시 개인정보 취급방침에 동의한 것으로 간주됩니다.</p>
          <button type="submit" class="btn btn--primary" id="cf-submit">
            <span id="cf-submit-text">Submit <span class="arrow">→</span></span>
          </button>
          <p class="form-status" id="cf-status" hidden></p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid { gap: 64px; align-items: start; }
  .contact-info-col { grid-column: span 5; }
  .contact-form-col { grid-column: span 7; }
  .contact-lead { margin: 24px 0 40px; }
  .contact-info-list { margin: 0; padding: 0; }
  .contact-info-row {
    display: grid; grid-template-columns: 100px 1fr;
    padding: 20px 0; border-top: 1px solid var(--color-border);
    align-items: start;
  }
  .contact-info-row:first-child { border-top: 0; }
  .contact-info-row dt {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em;
    color: var(--color-text-muted); text-transform: uppercase; padding-top: 4px;
  }
  .contact-info-row dd {
    margin: 0; color: var(--color-text); font-size: 15px; line-height: 1.6;
  }
  .contact-info-sub { color: var(--color-text-secondary); font-size: 14px; }
  .form-row { margin-bottom: 24px; }
  .form-row label {
    display: block; font-size: 13px; font-weight: 500; margin-bottom: 8px;
    color: var(--color-text);
  }
  .form-row input, .form-row textarea {
    width: 100%; padding: 12px 16px; font-size: 15px; font-family: inherit;
    border: 1px solid var(--color-border); background: var(--color-bg);
    color: var(--color-text); border-radius: 0;
    transition: border-color 200ms var(--ease);
  }
  .form-row input:focus, .form-row textarea:focus {
    outline: 2px solid var(--color-accent); outline-offset: 2px;
    border-color: var(--color-accent);
  }
  .form-err {
    display: block; font-size: 12px; color: #ef4444; margin-top: 6px; min-height: 14px;
  }
  .form-note { font-size: 12px; color: var(--color-text-muted); margin-bottom: 24px; }
  .form-status { font-size: 13px; margin-top: 16px; }
  .form-status.success { color: #22c55e; }
  .form-status.error { color: #ef4444; }
  @media (max-width: 1023px) {
    .contact-info-col, .contact-form-col { grid-column: 1 / -1; }
    .contact-grid { gap: 48px; }
  }
  @media (max-width: 767px) {
    .contact-info-row { grid-template-columns: 80px 1fr; gap: 12px; }
    .contact-lead { margin: 16px 0 32px; max-width: 100%; }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("cf-status");
  const submitBtn = document.getElementById("cf-submit") as HTMLButtonElement | null;
  const submitText = document.getElementById("cf-submit-text");

  const showErr = (field: string, msg: string) => {
    const el = document.querySelector(`[data-err="${field}"]`);
    if (el) el.textContent = msg;
  };
  const clearErrs = () => {
    document.querySelectorAll(".form-err").forEach(e => (e.textContent = ""));
  };

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrs();
    const fd = new FormData(form);
    const data = {
      name: String(fd.get("name") || "").trim(),
      company: String(fd.get("company") || "").trim(),
      email: String(fd.get("email") || "").trim(),
      message: String(fd.get("message") || "").trim(),
    };
    let ok = true;
    if (data.name.length < 2) { showErr("name", "성함을 입력해 주십시오."); ok = false; }
    if (!data.company) { showErr("company", "회사명을 입력해 주십시오."); ok = false; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) { showErr("email", "유효한 이메일을 입력해 주십시오."); ok = false; }
    if (data.message.length < 10) { showErr("message", "문의 내용을 10자 이상 입력해 주십시오."); ok = false; }
    if (!ok) return;

    if (submitBtn) submitBtn.disabled = true;
    if (submitText) submitText.textContent = "Sending…";

    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json", "Accept": "application/json" },
        body: JSON.stringify({
          access_key: "2ee7f387-4112-4119-901c-38debd517998",
          subject: `[dosang.kr] Briefing Request — ${data.company}`,
          ...data,
        }),
      });
      if (res.ok) {
        if (status) {
          status.textContent = "전송이 완료되었습니다. 24시간 내에 연락드리겠습니다.";
          status.className = "form-status success";
          status.hidden = false;
        }
        form.reset();
      } else {
        throw new Error("submit failed");
      }
    } catch {
      if (status) {
        status.textContent = "전송에 실패했습니다. 잠시 후 다시 시도해 주십시오.";
        status.className = "form-status error";
        status.hidden = false;
      }
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (submitText) submitText.innerHTML = 'Submit <span class="arrow">→</span>';
    }
  });
</script>
