---
const SOLS = [
  {
    code: "DAS", name: "Digital Asset & Financial Service Hub",
    summary: "SAP S/4HANA 기반 디지털자산(스테이블코인·NFT 등) 회계 자동화 솔루션",
    href: "/solutions/das", variant: "dark",
  },
  {
    code: "RDS", name: "Real Data Simulator",
    summary: "실데이터 기반 SAP 시뮬레이션·테스트 환경 솔루션",
    href: "/solutions/rds", variant: "subtle",
  },
  {
    code: "DBS", name: "Dosang Business Suite",
    summary: "도상 통합 비즈니스 운영 솔루션",
    href: "/solutions/dbs", variant: "outline",
  },
];
---
<section id="solutions" class="section">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">04 · Solutions</p>
      <h2 class="h-1">자체 솔루션</h2>
      <p class="lead measure">컨설팅 경험에서 추출된 도메인 IP — 표준 SAP 위에 얇게 얹는 도상 자체 솔루션.</p>
    </div>
    <div class="solutions-grid grid-12">
      {SOLS.map(s => (
        <article class={`solution-card solution-card--${s.variant} reveal`}>
          <div class="solution-card-content">
            <div class="solution-code">{s.code}</div>
            <h3 class="solution-name">{s.name}</h3>
            <p class="solution-summary">{s.summary}</p>
            <a href={s.href} class="solution-cta">상세 페이지 <span class="arrow">→</span></a>
          </div>
          <div class="solution-monogram" aria-hidden="true">{s.code}</div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .solutions-grid { grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .solution-card {
    grid-column: span 1;
    padding: 48px 40px 40px;
    position: relative;
    min-height: 320px;
    display: flex; flex-direction: column;
    border: 1px solid transparent;
    transition: transform 300ms var(--ease);
  }
  .solution-card:hover { transform: translateY(-2px); }
  .solution-card--dark {
    background: #0f2440; color: #fff;
  }
  .solution-card--subtle {
    background: var(--color-bg-subtle); color: var(--color-navy);
  }
  .solution-card--outline {
    background: var(--color-bg); color: var(--color-navy);
    border-color: var(--color-border);
  }
  .solution-card-content { flex: 1; }
  .solution-code {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.12em;
    margin-bottom: 24px; opacity: 0.7;
  }
  .solution-name {
    font-size: 22px; font-weight: 600; line-height: 1.3;
    margin: 0 0 16px; letter-spacing: -0.005em;
  }
  .solution-summary {
    font-size: 14px; line-height: 1.7; margin-bottom: 32px;
    opacity: 0.85;
  }
  .solution-cta {
    color: inherit; font-size: 13px; font-weight: 500;
    border-bottom: 1px solid currentColor; padding-bottom: 2px;
  }
  .solution-card--dark .solution-cta { color: #fff; }
  .solution-monogram {
    position: absolute; right: 32px; bottom: 32px;
    width: 64px; height: 48px;
    border: 1px solid currentColor;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 14px; font-weight: 600;
    letter-spacing: 0.08em; opacity: 0.5;
  }
  @media (max-width: 1023px) {
    .solutions-grid { grid-template-columns: 1fr; }
  }
</style>
