---
const links = [
  { href: "/#about", label: "About" },
  { href: "/#services", label: "Services" },
  { href: "/#solutions", label: "Solutions" },
  { href: "/insights", label: "Insights" },
  { href: "/#contact", label: "Contact" },
];
---
<header id="site-header">
  <div class="container header-inner">
    <a href="/" aria-label="Dosang LLC — Home" class="brand">
      <img src="/dosang-logo.svg" alt="" aria-hidden="true" class="brand-logo" />
      <span class="brand-text">DOSANG</span>
    </a>

    <nav class="header-nav" aria-label="Primary">
      <ul>
        {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <a href="/#contact" class="btn btn--primary header-cta">Enquire</a>

    <button id="header-burger" class="header-burger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div id="header-drawer" class="header-drawer" hidden>
    <ul>
      {links.map(l => <li><a href={l.href} class="drawer-link">{l.label}</a></li>)}
      <li><a href="/#contact" class="btn btn--primary drawer-link">Enquire</a></li>
    </ul>
  </div>
</header>

<style>
  #site-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: saturate(150%) blur(12px);
    -webkit-backdrop-filter: saturate(150%) blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: all 300ms cubic-bezier(0.2, 0, 0, 1);
    height: 72px;
  }
  #site-header.shrunk { height: 56px; }
  .header-inner {
    height: 100%;
    display: flex; align-items: center; justify-content: space-between;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 12px; text-decoration: none;
  }
  .brand-logo { width: 32px; height: 32px; }
  .brand-text {
    font-family: var(--font-sans-en);
    font-weight: 600; font-size: 17px; letter-spacing: 0.02em;
    color: #0f2440;
  }
  .header-nav ul {
    display: flex; gap: 36px; list-style: none; margin: 0; padding: 0;
  }
  .header-nav a {
    color: var(--color-text); font-size: 14px; font-weight: 500; letter-spacing: 0.01em;
    text-decoration: none; transition: color 300ms var(--ease);
  }
  .header-nav a:hover { color: var(--color-accent); }
  .header-cta { padding: 10px 18px; }
  .header-burger {
    background: transparent; border: 0; padding: 8px; display: none;
  }
  .header-burger span {
    display: block; width: 22px; height: 1.5px; background: var(--color-text); margin-bottom: 6px;
  }
  .header-burger span:last-child { margin-bottom: 0; }
  .header-drawer {
    background: #fff;
    border-top: 1px solid var(--color-border);
    padding: 16px 20px 24px;
  }
  .header-drawer ul {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 12px;
  }
  .header-drawer a { color: var(--color-text); font-size: 16px; font-weight: 500; text-decoration: none; }

  @media (max-width: 767px) {
    .header-nav, .header-cta { display: none; }
    .header-burger { display: block; }
  }
  @media (min-width: 768px) {
    .header-drawer { display: none !important; }
  }
</style>

<script>
  // Header shrink on scroll
  const hdr = document.getElementById("site-header");
  if (hdr) {
    const onScroll = () => {
      if (window.scrollY > 80) hdr.classList.add("shrunk");
      else hdr.classList.remove("shrunk");
    };
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  // Mobile drawer toggle
  const burger = document.getElementById("header-burger");
  const drawer = document.getElementById("header-drawer");
  if (burger && drawer) {
    burger.addEventListener("click", () => {
      const expanded = burger.getAttribute("aria-expanded") === "true";
      burger.setAttribute("aria-expanded", String(!expanded));
      drawer.hidden = expanded;
    });
    drawer.querySelectorAll(".drawer-link").forEach(a => {
      a.addEventListener("click", () => {
        burger.setAttribute("aria-expanded", "false");
        drawer.hidden = true;
      });
    });
  }
</script>
