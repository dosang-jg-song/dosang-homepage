---
const CAPS = [
  ["C.01", "Multi-chain Ingestion", "7개 주요 체인의 트랜잭션 데이터를 정규화하여 SAP에 적재합니다."],
  ["C.02", "IFRS / K-IFRS 분개", "자산 분류와 평가 모델별 분개 규칙을 표준 GL에 매핑합니다."],
  ["C.03", "Fair Value Engine", "다중 시세 소스 중간값을 사용한 평가, 회기 마감 자동화."],
  ["C.04", "On-chain Reconciliation", "Hash 단위 매칭과 차이 발생 시 자동 워크플로 트리거."],
  ["C.05", "Treasury Integration", "SAP Treasury · Cash Mgmt와 동일 마스터로 연계."],
  ["C.06", "Audit Trail", "모든 평가·분개 이벤트의 불변 로그를 보존합니다."],
];
const SCENARIOS = [
  ["SCN.01", "스테이블코인 결제 통합", "글로벌 자회사 간 USDC 결제를 SAP 표준 결제 흐름에 통합. 환산 손익 자동 분개.", [["Industry", "FinTech"], ["Volume", "€120M / qtr"]]],
  ["SCN.02", "토큰화 증권 보유", "온체인 발행 증권의 보유·평가·이자 분개를 SAP Treasury와 일관된 흐름으로 처리.", [["Industry", "Banking"], ["Coverage", "5 chains"]]],
  ["SCN.03", "Loyalty NFT 회계", "발행·소각·교환 이벤트를 수익 인식 기준에 맞춰 자동 분개합니다.", [["Industry", "Retail"], ["Audit", "PASS · FY25"]]],
];
const STEPS = [
  ["P.01", "Discovery", "대상 자산·체인·관할권 인벤토리 작성, gap 분석."],
  ["P.02", "Design", "분개 규칙·평가 모델·통제 포인트의 설계 문서화."],
  ["P.03", "Build", "엔진 구성, SAP 객체 활성화, 데이터 매핑 검증."],
  ["P.04", "Validate", "감사 시뮬레이션, 회귀 검증, SoD 점검."],
  ["P.05", "Hyper-care", "90일 운영 안정화, KPI 측정 및 인계."],
];
---

<!-- Hero (dark) -->
<section class="das-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">Home</a> · <a href="/#solutions">Solutions</a> · DAS</div>
    <div class="das-hero-content">
      <div class="das-hero-meta-row">
        <div class="das-monogram">DAS</div>
        <div class="das-hero-tag">Solution · Code DAS</div>
      </div>
      <h1 class="h-display das-hero-title">
        Digital Asset &amp;<br />Financial Service Hub.
      </h1>
      <p class="lead das-hero-lead">
        SAP S/4HANA 위에서 디지털자산 — 스테이블코인, 토큰화 증권, NFT — 의 평가·분개·보고를
        표준 GL 흐름과 일관된 거버넌스로 통합합니다.
      </p>
    </div>
    <div class="das-meta">
      <div class="das-meta-item"><div class="k">Status</div><div class="v">GA · v.2026.01</div></div>
      <div class="das-meta-item"><div class="k">Platform</div><div class="v">SAP S/4HANA 2023+</div></div>
      <div class="das-meta-item"><div class="k">Deployment</div><div class="v">Private / RISE</div></div>
      <div class="das-meta-item"><div class="k">Time-to-value</div><div class="v">8 — 14 weeks</div></div>
    </div>
  </div>
</section>

<!-- 01 Problem -->
<section class="section">
  <div class="container">
    <div class="section-title-row">
      <div><div class="eyebrow">01 / Problem</div></div>
      <div>
        <h2 class="h-2 das-title">디지털자산은 회계 표준의 사각지대에서 운영됩니다.</h2>
        <div class="lead measure das-lead">
          가격 변동성, 다중 체인 출처, 무형 vs 금융자산 분류 모호성으로 인해
          디지털자산의 회계 처리는 수작업·스프레드시트 의존적인 프로세스에 머물러 있습니다.
        </div>
        <p class="measure das-body">
          감사인은 정합성과 추적 가능성을, CFO는 분개의 일관성과 통제 가능성을 요구합니다.
          두 요구를 동시에 만족시키려면 SAP 표준 GL 위에서 작동하는 도메인 특화 엔진이 필요합니다.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- 02 Capabilities -->
<section class="section section--subtle">
  <div class="container">
    <div class="section-title-row">
      <div><div class="eyebrow">02 / Capabilities</div></div>
      <div>
        <h2 class="h-2 das-title">핵심 기능 6개.</h2>
        <p class="lead measure">SAP 표준을 우회하지 않습니다. 모든 산출물은 표준 BAPI · CDS · CO 객체로 귀결됩니다.</p>
      </div>
    </div>
    <div class="cap-grid">
      {CAPS.map(([code, title, desc]) => (
        <div class="cap">
          <div class="cap-code">{code}</div>
          <h3 class="h-3 cap-title">{title}</h3>
          <p class="cap-desc">{desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 03 Architecture -->
<section class="section">
  <div class="container">
    <div class="section-title-row">
      <div><div class="eyebrow">03 / Architecture</div></div>
      <div>
        <h2 class="h-2 das-title">표준 위의 얇은 레이어.</h2>
        <p class="lead measure">DAS는 SAP S/4HANA 위에 추가되는 얇은 도메인 레이어로 구성됩니다. 코어 모듈을 개조하지 않습니다.</p>
      </div>
    </div>
    <figure class="arch-figure">
      <svg viewBox="0 0 1200 460" width="100%" aria-label="DAS Architecture Diagram">
        <g font-family="ui-monospace, SF Mono, Menlo, monospace" font-size="11" fill="#8a919c" letter-spacing="1">
          <text x="0" y="40">L4 — INGESTION</text>
          <text x="0" y="160">L3 — DOMAIN ENGINE</text>
          <text x="0" y="280">L2 — SAP CORE</text>
          <text x="0" y="400">L1 — INFRA</text>
        </g>
        <g>
          <rect x="180" y="20" width="180" height="50" fill="#fff" stroke="#1a3a5c" stroke-width="1" />
          <text x="270" y="50" text-anchor="middle" font-size="13" fill="#1a3a5c" font-weight="500">Chain Connectors</text>
          <rect x="380" y="20" width="180" height="50" fill="#fff" stroke="#1a3a5c" stroke-width="1" />
          <text x="470" y="50" text-anchor="middle" font-size="13" fill="#1a3a5c" font-weight="500">Price Oracles</text>
          <rect x="580" y="20" width="180" height="50" fill="#fff" stroke="#1a3a5c" stroke-width="1" />
          <text x="670" y="50" text-anchor="middle" font-size="13" fill="#1a3a5c" font-weight="500">Custodian APIs</text>
          <rect x="780" y="20" width="180" height="50" fill="#fff" stroke="#1a3a5c" stroke-width="1" />
          <text x="870" y="50" text-anchor="middle" font-size="13" fill="#1a3a5c" font-weight="500">Internal Wallets</text>
        </g>
        <g>
          <rect x="180" y="120" width="780" height="80" fill="#0f2440" stroke="#0f2440" />
          <text x="570" y="148" text-anchor="middle" font-size="14" fill="#fff" font-weight="600">DAS Domain Engine</text>
          <text x="570" y="172" text-anchor="middle" font-family="ui-monospace, SF Mono, Menlo, monospace" font-size="11" fill="rgba(255,255,255,0.7)">
            Classification · Fair Value · Posting Rules · Reconciliation
          </text>
        </g>
        <g>
          <rect x="180" y="240" width="180" height="50" fill="#f5f7fa" stroke="#c9d0db" stroke-width="1" />
          <text x="270" y="270" text-anchor="middle" font-size="13" fill="#0f2440" font-weight="500">FI / GL</text>
          <rect x="380" y="240" width="180" height="50" fill="#f5f7fa" stroke="#c9d0db" stroke-width="1" />
          <text x="470" y="270" text-anchor="middle" font-size="13" fill="#0f2440" font-weight="500">CO</text>
          <rect x="580" y="240" width="180" height="50" fill="#f5f7fa" stroke="#c9d0db" stroke-width="1" />
          <text x="670" y="270" text-anchor="middle" font-size="13" fill="#0f2440" font-weight="500">Treasury</text>
          <rect x="780" y="240" width="180" height="50" fill="#f5f7fa" stroke="#c9d0db" stroke-width="1" />
          <text x="870" y="270" text-anchor="middle" font-size="13" fill="#0f2440" font-weight="500">DRC</text>
        </g>
        <g>
          <rect x="180" y="360" width="780" height="50" fill="#fff" stroke="#e2e6ec" stroke-width="1" stroke-dasharray="3 3" />
          <text x="570" y="390" text-anchor="middle" font-size="13" fill="#5a6270">SAP HANA · BTP · Audit Vault</text>
        </g>
        <g stroke="#c9d0db" stroke-width="1">
          <line x1="270" y1="70" x2="270" y2="120" /><line x1="470" y1="70" x2="470" y2="120" />
          <line x1="670" y1="70" x2="670" y2="120" /><line x1="870" y1="70" x2="870" y2="120" />
          <line x1="270" y1="200" x2="270" y2="240" /><line x1="470" y1="200" x2="470" y2="240" />
          <line x1="670" y1="200" x2="670" y2="240" /><line x1="870" y1="200" x2="870" y2="240" />
          <line x1="570" y1="290" x2="570" y2="360" stroke-dasharray="3 3" />
        </g>
        <text x="1140" y="40" text-anchor="end" font-family="ui-monospace, SF Mono, Menlo, monospace" font-size="10" fill="#8a919c">FIG.DAS-01</text>
      </svg>
      <figcaption class="arch-caption">FIG.DAS-01 — DAS Layered Architecture</figcaption>
    </figure>
  </div>
</section>

<!-- 04 Scenarios -->
<section class="section section--subtle">
  <div class="container">
    <div class="section-title-row">
      <div><div class="eyebrow">04 / Scenarios</div></div>
      <div><h2 class="h-2">대표 시나리오 3.</h2></div>
    </div>
    <div class="scenario-grid">
      {SCENARIOS.map(([code, title, desc, meta]) => (
        <article class="scenario-card">
          <div class="scenario-code">{code}</div>
          <h3 class="h-3 scenario-title">{title}</h3>
          <p class="scenario-desc">{desc}</p>
          <dl class="scenario-meta">
            {(meta as [string, string][]).map(([k, v]) => (
              <div class="scenario-meta-row"><dt>{k}</dt><dd>{v}</dd></div>
            ))}
          </dl>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- 05 Implementation -->
<section class="section">
  <div class="container">
    <div class="section-title-row">
      <div><div class="eyebrow">05 / Implementation</div></div>
      <div>
        <h2 class="h-2 das-title">도입 절차 — 5단계.</h2>
        <p class="lead measure">평균 12주. 모든 단계는 명시적 게이트와 산출물을 가집니다.</p>
      </div>
    </div>
    <div class="step-grid">
      {STEPS.map(([code, title, desc]) => (
        <div class="step">
          <div class="step-code">{code}</div>
          <h3 class="step-title">{title}</h3>
          <p class="step-desc">{desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section das-cta">
  <div class="container">
    <div class="cta-grid">
      <div>
        <div class="eyebrow das-cta-eyebrow">Next</div>
        <h2 class="h-1 das-cta-title">DAS가 귀사 환경에 적합한지<br />30분 이내에 확인합니다.</h2>
        <p class="das-cta-lead">파트너가 직접 진행하는 무상 진단 세션. NDA 기반.</p>
      </div>
      <div>
        <a href="/#contact" class="btn btn--primary">Request Briefing <span class="arrow">→</span></a>
      </div>
    </div>
  </div>
</section>

<style>
  .das-hero { background: #0f2440; color: #fff; padding: 160px 0 96px; }
  .das-hero .breadcrumb { font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; }
  .das-hero .breadcrumb a { color: rgba(255,255,255,0.7); }
  .das-hero-content { margin-top: 32px; max-width: 880px; }
  .das-hero-meta-row { display: flex; align-items: center; gap: 16px; margin-bottom: 32px; }
  .das-monogram { width: 56px; height: 56px; border: 1px solid rgba(255,255,255,0.4); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-weight: 600; letter-spacing: 0.08em; }
  .das-hero-tag { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.12em; color: rgba(255,255,255,0.6); text-transform: uppercase; }
  .das-hero-title { color: #fff; margin-bottom: 28px; }
  .das-hero-lead { color: rgba(255,255,255,0.85); max-width: 720px; margin-bottom: 12px; }
  .das-meta { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; margin-top: 56px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.12); }
  .das-meta-item .k { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; color: rgba(255,255,255,0.5); text-transform: uppercase; margin-bottom: 8px; }
  .das-meta-item .v { font-size: 14px; color: #fff; }
  .section-title-row { display: grid; grid-template-columns: 200px 1fr; gap: 32px; align-items: start; }
  .das-title { margin-bottom: 24px; }
  .das-lead { margin-bottom: 24px; }
  .das-body { color: var(--color-text-secondary); }
  .cap-grid { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--color-border); border-left: 1px solid var(--color-border); margin-top: 48px; }
  .cap { padding: 40px; border-right: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); background: #fff; }
  .cap-code { font-family: var(--font-mono); font-size: 13px; color: var(--color-accent); margin-bottom: 24px; }
  .cap-title { margin-bottom: 12px; }
  .cap-desc { color: var(--color-text-secondary); font-size: 15px; margin: 0; }
  .arch-figure { margin: 48px 0 0; }
  .arch-caption { font-family: var(--font-mono); font-size: 12px; color: var(--color-text-muted); margin-top: 24px; text-align: center; }
  .scenario-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
  .scenario-card { background: #fff; border: 1px solid var(--color-border); padding: 40px; }
  .scenario-code { font-family: var(--font-mono); font-size: 12px; color: var(--color-accent); margin-bottom: 20px; }
  .scenario-title { margin-bottom: 16px; }
  .scenario-desc { color: var(--color-text-secondary); font-size: 15px; margin: 0 0 24px; }
  .scenario-meta { margin: 0; font-size: 13px; color: var(--color-text-muted); border-top: 1px solid var(--color-border); padding-top: 16px; }
  .scenario-meta-row { display: flex; justify-content: space-between; padding: 6px 0; }
  .scenario-meta-row dd { margin: 0; }
  .step-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 24px; margin-top: 48px; }
  .step { padding: 24px 0; border-top: 1px solid var(--color-border); }
  .step-code { font-family: var(--font-mono); font-size: 13px; color: var(--color-accent); margin-bottom: 24px; }
  .step-title { font-size: 17px; font-weight: 600; color: var(--color-navy); margin: 0 0 12px; }
  .step-desc { font-size: 14px; color: var(--color-text-secondary); margin: 0; }
  .das-cta { background: #0c1926; color: #fff; }
  .cta-grid { display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center; }
  .das-cta-eyebrow { color: rgba(255,255,255,0.6); margin-bottom: 16px; }
  .das-cta-title { color: #fff; margin: 0 0 16px; }
  .das-cta-lead { color: rgba(255,255,255,0.7); max-width: 560px; margin: 0; font-size: 17px; }
  @media (max-width: 1023px) {
    .section-title-row { grid-template-columns: 1fr; }
    .cap-grid { grid-template-columns: repeat(2, 1fr); }
    .scenario-grid { grid-template-columns: 1fr; }
    .step-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-grid { grid-template-columns: 1fr; }
    .das-meta { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 767px) {
    .cap-grid { grid-template-columns: 1fr; }
    .step-grid { grid-template-columns: 1fr; }
    .das-meta { grid-template-columns: 1fr; }
  }
</style>
