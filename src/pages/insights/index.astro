---
import { getCollection } from 'astro:content';
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const allInsights = await getCollection('insights');
const sorted = allInsights.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = ['Global Tax', 'SAP 전환', 'Tax Compliance', 'AX'] as const;
const CAT_COLOR = {
  'Global Tax': 'var(--color-accent)',
  'SAP 전환': 'var(--color-navy)',
  'Tax Compliance': '#22c55e',
  'AX': '#f59e0b',
} as const;
---
<BaseLayout
  title="Insights | Dosang LLC"
  description="SAP S/4HANA · Global Tax · Tax Compliance · AX 4개 카테고리 컨설팅 인사이트"
>
  <Header />
  <main id="main">
    <section class="insights-hero">
      <div class="container">
        <p class="eyebrow">Insights</p>
        <h1 class="h-display insights-title">컨설팅 인사이트</h1>
        <p class="lead measure">
          글로벌 SAP S/4HANA·Global Tax·Tax Compliance·AX 영역의 도상 컨설팅 경험을
          정기적으로 발행합니다. 모든 분석은 도상 컨설팅팀의 실무 경험을 기반으로 합니다.
        </p>
      </div>
    </section>

    <section class="section insights-list-section">
      <div class="container">
        <div class="cat-filter">
          <button class="cat-btn cat-btn--active" data-cat="all" aria-pressed="true">All ({sorted.length})</button>
          {categories.map(c => {
            const count = sorted.filter(p => p.data.category === c).length;
            return (
              <button class="cat-btn" data-cat={c} aria-pressed="false" style={`--cat-color:${CAT_COLOR[c]}`}>
                {c} ({count})
              </button>
            );
          })}
        </div>

        <div class="insights-card-grid">
          {sorted.map((post, i) => (
            <article class="insight-card" data-cat={post.data.category}>
              <div class="insight-thumb" aria-hidden="true">
                <span class="insight-fig">FIG.{(i + 1).toString().padStart(2, "0")}</span>
              </div>
              <div class="insight-meta">
                <span class="insight-cat" style={`color:${CAT_COLOR[post.data.category]}; border-color:${CAT_COLOR[post.data.category]}`}>{post.data.category}</span>
                <span class="insight-date">{post.data.date.toISOString().slice(0, 10).replace(/-/g, '.')}</span>
                <span class="insight-read">{post.data.readMin} min read</span>
              </div>
              <h3 class="insight-title">{post.data.title}</h3>
              <p class="insight-summary">{post.data.summary}</p>
              <a href={`/insights/${post.slug}`} class="insight-link">읽기 <span class="arrow">→</span></a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .insights-hero {
    padding: 160px 0 80px;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .insights-title { margin: 24px 0 32px; }
  .insights-list-section { padding-top: 64px; }

  .cat-filter {
    display: flex; gap: 8px; flex-wrap: wrap;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 16px 0;
    margin-bottom: 64px;
  }
  .cat-btn {
    background: transparent;
    border: 1px solid var(--color-border);
    padding: 8px 16px;
    font-family: var(--font-mono);
    font-size: 12px; letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 200ms var(--ease);
  }
  .cat-btn:hover { border-color: var(--color-navy); color: var(--color-navy); }
  .cat-btn--active {
    background: var(--color-navy); border-color: var(--color-navy); color: #fff;
  }

  .insights-card-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 48px 32px;
  }
  .insight-card { display: flex; flex-direction: column; }
  .insight-card[hidden] { display: none; }
  .insight-thumb {
    background: #0f2440; aspect-ratio: 16 / 9; margin-bottom: 24px;
    display: flex; align-items: center; justify-content: center;
    background-image: linear-gradient(135deg, transparent 49%, rgba(255,255,255,0.06) 49%, rgba(255,255,255,0.06) 51%, transparent 51%);
    background-size: 14px 14px;
  }
  .insight-fig {
    color: rgba(255,255,255,0.6); font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.12em; padding: 6px 10px; border: 1px solid rgba(255,255,255,0.2);
  }
  .insight-meta {
    display: flex; align-items: center; gap: 12px; margin-bottom: 12px; flex-wrap: wrap;
  }
  .insight-cat {
    display: inline-block; padding: 4px 10px; border: 1px solid;
    font-size: 11px; font-family: var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase;
  }
  .insight-date, .insight-read {
    font-family: var(--font-mono); font-size: 11px; color: var(--color-text-muted);
    letter-spacing: 0.06em;
  }
  .insight-title {
    font-size: 18px; font-weight: 600; line-height: 1.4; color: var(--color-navy);
    margin: 0 0 12px; letter-spacing: -0.005em;
  }
  .insight-summary {
    font-size: 14px; line-height: 1.7; color: var(--color-text-secondary); margin-bottom: 20px;
  }
  .insight-link {
    color: var(--color-accent); font-size: 13px; font-weight: 500; margin-top: auto;
  }

  @media (max-width: 1023px) {
    .insights-card-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 767px) {
    .insights-card-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>

<script>
  // 카테고리 필터
  const btns = document.querySelectorAll<HTMLButtonElement>(".cat-btn");
  const cards = document.querySelectorAll<HTMLElement>(".insight-card");

  btns.forEach(btn => {
    btn.addEventListener("click", () => {
      const cat = btn.dataset.cat;
      btns.forEach(b => {
        b.classList.toggle("cat-btn--active", b === btn);
        b.setAttribute("aria-pressed", String(b === btn));
      });
      cards.forEach(c => {
        if (cat === "all" || c.dataset.cat === cat) c.hidden = false;
        else c.hidden = true;
      });
    });
  });
</script>
